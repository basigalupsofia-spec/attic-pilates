---
const videoCdn = 'https://res.cloudinary.com/dot4vmp1c/video/upload';
const imageCdn = 'https://res.cloudinary.com/dot4vmp1c/image/upload';
---

<section class="hero">
  <div class="hero-bg">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="hero-video"
      poster={`${imageCdn}/f_auto,q_auto,w_1600/attic-pilates/hero`}
    >
      <source src={`${videoCdn}/f_auto,q_auto/attic-pilates/hero-video`} type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content container">
    <div class="hero-text">
      <p class="hero-location">Palermo Soho, Buenos Aires</p>
      <h1>Transformá tu cuerpo,<br />encontrá tu <em>equilibrio</em></h1>
      <p class="hero-desc">
        Reformer &middot; Cadillac &middot; Barre
      </p>
      <div class="hero-buttons">
        <a href="#contacto" class="btn btn-primary">
          Reservá tu clase
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#clases" class="btn btn-outline">Conocé más</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(245, 240, 232, 0.8) 0%,
      rgba(245, 240, 232, 0.65) 35%,
      rgba(245, 240, 232, 0.45) 70%,
      rgba(245, 240, 232, 0.2) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
  }

  .hero-text {
    max-width: 600px;
  }

  .hero-location {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  h1 {
    margin-bottom: var(--space-md);
    color: var(--color-dark);
  }

  h1 em {
    font-style: italic;
    color: var(--color-gold);
  }

  .hero-desc {
    font-size: 1.15rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--color-dark-soft);
    margin-bottom: var(--space-lg);
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
    }

    .hero-overlay {
      background: linear-gradient(
        180deg,
        rgba(245, 240, 232, 0.97) 0%,
        rgba(245, 240, 232, 0.93) 50%,
        rgba(245, 240, 232, 0.7) 100%
      );
    }

    .hero-content {
      padding-top: 7rem;
    }

    .hero-buttons {
      flex-direction: column;
    }

    .hero-buttons .btn {
      text-align: center;
      justify-content: center;
    }
  }
</style>
