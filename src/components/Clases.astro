---
const clases = [
  {
    title: 'Reformer',
    description: 'Una máquina con resortes y poleas que trabaja todo el cuerpo con resistencia. Tonifica, alarga y fortalece sin impacto en las articulaciones. Es la clase estrella del estudio — apta para todo nivel, desde principiantes hasta avanzados.',
    icon: '01',
  },
  {
    title: 'Cadillac',
    description: 'El equipo más completo del Pilates: una cama con barras, resortes y poleas que permite trabajar en planos y ángulos imposibles en el suelo. Sesión privada y personalizada, enfocada en tus objetivos específicos.',
    icon: '02',
  },
  {
    title: 'Barre',
    description: 'Clases paradas frente a la barra, combinando movimientos de ballet con ejercicios de fuerza y Pilates. Trabaja glúteos, piernas y core con mucha repetición y poca carga. Sin experiencia en danza requerida.',
    icon: '03',
  },
];
---

<section class="section clases" id="clases">
  <div class="container">
    <div class="clases-header">
      <p class="subtitle">Nuestras disciplinas</p>
      <h2>Elegí tu experiencia</h2>
    </div>

    <div class="clases-grid">
      {clases.map((clase) => (
        <div class="clase-card">
          <span class="clase-number">{clase.icon}</span>
          <h3>{clase.title}</h3>
          <p>{clase.description}</p>
          <a href="https://www.siguefit.com" target="_blank" rel="noopener" class="clase-link">
            Reservar
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clases-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .clases-header .subtitle {
    justify-content: center;
  }

  .clases-header .subtitle::before {
    display: none;
  }

  .clases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid rgba(45, 41, 38, 0.1);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .clase-card {
    padding: var(--space-lg);
    border-right: 1px solid rgba(45, 41, 38, 0.1);
    transition: background var(--transition);
  }

  .clase-card:last-child {
    border-right: none;
  }

  .clase-card:hover {
    background: rgba(45, 41, 38, 0.02);
  }

  .clase-number {
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--color-taupe);
    display: block;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .clase-card h3 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .clase-card p {
    font-size: 0.875rem;
    margin-bottom: var(--space-sm);
    line-height: 1.65;
  }

  .clase-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-dark);
    transition: gap var(--transition);
  }

  .clase-link:hover {
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .clases-grid {
      grid-template-columns: 1fr;
    }

    .clase-card {
      border-right: none;
      border-bottom: 1px solid rgba(45, 41, 38, 0.1);
    }

    .clase-card:last-child {
      border-bottom: none;
    }
  }
</style>
