---
const base = import.meta.env.BASE_URL;

const clases = [
  {
    title: 'Reformer',
    description: 'Fortalecé y tonificá todo tu cuerpo con ejercicios de resistencia controlada. Grupal o privado, todos los niveles.',
    icon: '01',
    modalidad: 'Grupal / Privado',
  },
  {
    title: 'Barre',
    description: 'Fusión de ballet, Pilates y fitness. Clases dinámicas que esculpen, alargan y definen tu musculatura.',
    icon: '02',
    modalidad: 'Grupal',
  },
  {
    title: 'Yoga',
    description: 'Movimiento consciente, respiración y fuerza. Clases para conectar cuerpo y mente con base técnica.',
    icon: '03',
    modalidad: 'Grupal',
  },
  {
    title: 'Cadillac',
    description: 'El equipo más versátil de Pilates. Trabajá flexibilidad, fuerza y alineación postural en sesiones personalizadas.',
    icon: '04',
    modalidad: 'Privado',
  },
];
---

<section class="section clases" id="clases">
  <div class="container">
    <div class="clases-header">
      <p class="subtitle">Nuestras disciplinas</p>
      <h2>Elegí tu experiencia</h2>
    </div>

    <div class="clases-grid">
      {clases.map((clase) => (
        <div class="clase-card">
          <div class="clase-top">
            <span class="clase-number">{clase.icon}</span>
            <span class="clase-badge">{clase.modalidad}</span>
          </div>
          <h3>{clase.title}</h3>
          <p>{clase.description}</p>
          <a href="https://www.siguefit.com" target="_blank" rel="noopener" class="clase-link">
            Reservar
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clases {
    background-color: var(--color-bg-alt);
  }

  .clases-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .clases-header .subtitle {
    justify-content: center;
  }

  .clases-header .subtitle::before {
    display: none;
  }

  .clases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .clase-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  .clase-badge {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-taupe);
    border: 1px solid var(--color-taupe);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .clase-card {
    background: var(--color-cream);
    padding: var(--space-xl) var(--space-lg);
    border-radius: var(--border-radius-lg);
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
    border: 1px solid transparent;
  }

  .clase-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-dark);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .clase-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(45, 41, 38, 0.07);
  }

  .clase-card:hover::before {
    opacity: 1;
  }

  .clase-number {
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-taupe);
    display: block;
    margin-bottom: var(--space-sm);
    letter-spacing: 0.05em;
  }

  .clase-card h3 {
    margin-bottom: var(--space-sm);
    font-weight: 500;
  }

  .clase-card p {
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .clase-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-dark);
    transition: gap var(--transition);
  }

  .clase-link:hover {
    gap: 0.8rem;
  }

  @media (max-width: 768px) {
    .clases-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .clase-card {
      padding: var(--space-lg);
    }
  }
</style>
