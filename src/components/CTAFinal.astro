---

<section class="cta-final" id="contacto">
  <div class="container">
    <p class="cta-eyebrow">Palermo Soho, Buenos Aires</p>
    <h2>¿Arrancamos?</h2>
    <p class="cta-desc">
      Reservá tu primera clase en línea o escribinos por WhatsApp.
      Sin compromiso, sin formularios.
    </p>
    <div class="cta-actions">
      <a href="https://www.siguefit.com" target="_blank" rel="noopener" class="btn btn-cream">
        Reservar en Siguefit
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://wa.me/" target="_blank" rel="noopener" class="cta-wa">
        También por WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--color-dark);
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .cta-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-taupe);
    margin-bottom: var(--space-sm);
  }

  .cta-final h2 {
    color: var(--color-cream);
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-bottom: var(--space-md);
  }

  .cta-desc {
    color: rgba(242, 239, 230, 0.55);
    font-size: 1rem;
    max-width: 420px;
    margin: 0 auto var(--space-xl);
    line-height: 1.75;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .btn-cream {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    background: var(--color-cream);
    color: var(--color-dark);
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all var(--transition);
    border: none;
    cursor: pointer;
  }

  .btn-cream:hover {
    background: var(--color-taupe);
    color: var(--color-cream);
    transform: translateY(-2px);
  }

  .cta-wa {
    font-size: 0.8rem;
    color: rgba(242, 239, 230, 0.4);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition);
  }

  .cta-wa:hover {
    color: rgba(242, 239, 230, 0.7);
  }

  @media (max-width: 768px) {
    .btn-cream {
      width: 100%;
      max-width: 320px;
      justify-content: center;
    }
  }
</style>
