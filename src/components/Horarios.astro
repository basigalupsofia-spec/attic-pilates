---
type Clase = { tipo: string; profe: string } | null;

const horarios: Record<string, Record<string, Clase>> = {
  '8:00':  { lun: {tipo:'Pilates',profe:'Camila'}, mar: {tipo:'Pilates',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Nacho'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Nacho'}, sab: null },
  '9:00':  { lun: {tipo:'Pilates',profe:'Camila'}, mar: {tipo:'Pilates',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Nacho'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Nacho'}, sab: null },
  '10:00': { lun: {tipo:'Pilates',profe:'Camila'}, mar: {tipo:'Pilates',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Nacho'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Nacho'}, sab: {tipo:'Pilates',profe:'Nacho'} },
  '11:00': { lun: null, mar: {tipo:'Cadillac',profe:'Lorena'}, mie: null, jue: null, vie: null, sab: {tipo:'Pilates',profe:'Nacho'} },
  '12:00': { lun: null, mar: null, mie: null, jue: null, vie: null, sab: {tipo:'Pilates',profe:'Nacho'} },
  '13:00': { lun: null, mar: null, mie: null, jue: null, vie: null, sab: {tipo:'Cadillac',profe:'Lorena'} },
  '16:00': { lun: null, mar: null, mie: null, jue: null, vie: {tipo:'Cadillac',profe:'Camila'}, sab: null },
  '17:00': { lun: {tipo:'Pilates',profe:'Nacho'}, mar: {tipo:'Pilates',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Lorena'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Camila'}, sab: null },
  '18:00': { lun: {tipo:'Pilates',profe:'Nacho'}, mar: {tipo:'Barre',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Lorena'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Camila'}, sab: null },
  '19:00': { lun: {tipo:'Pilates',profe:'Nacho'}, mar: {tipo:'Pilates',profe:'Lorena'}, mie: {tipo:'Pilates',profe:'Lorena'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: {tipo:'Pilates',profe:'Camila'}, sab: null },
  '20:00': { lun: null, mar: null, mie: {tipo:'Pilates',profe:'Lorena'}, jue: {tipo:'Pilates',profe:'Lorena'}, vie: null, sab: null },
};

const dias = [
  { key: 'lun', label: 'Lunes' },
  { key: 'mar', label: 'Martes' },
  { key: 'mie', label: 'Miércoles' },
  { key: 'jue', label: 'Jueves' },
  { key: 'vie', label: 'Viernes' },
  { key: 'sab', label: 'Sábado' },
];
---

<section class="section horarios" id="horarios">
  <div class="container">
    <div class="horarios-header">
      <p class="subtitle">Planificá tu semana</p>
      <h2>Horarios</h2>
    </div>

    <div class="table-wrapper">
      <table class="tabla">
        <thead>
          <tr>
            <th class="th-hora"></th>
            {dias.map(d => <th>{d.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {Object.entries(horarios).map(([hora, fila]) => (
            <tr>
              <td class="td-hora">{hora}</td>
              {dias.map(d => {
                const c = fila[d.key];
                return (
                  <td class={`td-clase ${c ? 'has-clase' : ''} ${c?.tipo === 'Cadillac' ? 'is-cadillac' : ''} ${c?.tipo === 'Barre' ? 'is-barre' : ''}`}>
                    {c && (
                      <span class="clase-info">
                        <span class="clase-tipo">{c.tipo}</span>
                        <span class="clase-profe">{c.profe}</span>
                      </span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .horarios-header {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tabla {
    width: 100%;
    border-collapse: collapse;
    min-width: 560px;
    font-size: 0.75rem;
  }

  .tabla thead th {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-taupe);
    padding: 0 0.25rem 0.6rem;
    text-align: center;
  }

  .th-hora { width: 48px; }

  .tabla tbody tr:not(:last-child) td {
    border-bottom: 1px solid rgba(45, 41, 38, 0.05);
  }

  .td-hora {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-taupe);
    padding: 0.25rem 0.5rem 0.25rem 0;
    white-space: nowrap;
    vertical-align: middle;
  }

  .td-clase {
    padding: 0.2rem 0.2rem;
    text-align: center;
    vertical-align: middle;
    height: 40px;
  }

  .clase-info {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    background: rgba(45, 41, 38, 0.06);
    border-radius: 6px;
    padding: 0.25rem 0.4rem;
    width: 100%;
    max-width: 90px;
    gap: 1px;
  }

  .is-cadillac .clase-info { background: rgba(182, 168, 154, 0.25); }

  .is-barre .clase-info {
    background: rgba(182, 168, 154, 0.18);
    border: 1px solid rgba(182, 168, 154, 0.4);
  }

  .clase-tipo {
    font-weight: 600;
    color: var(--color-dark);
    font-size: 0.68rem;
  }

  .clase-profe {
    font-size: 0.6rem;
    color: var(--color-taupe);
  }
</style>
